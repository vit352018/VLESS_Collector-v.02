# ════════════════════════════════════════════════════════════
#  Настройки для локального запуска
#  Скопируй в .env и заполни своими данными
#  Файл .env НИКОГДА не попадёт на GitHub (он в .gitignore)
# ════════════════════════════════════════════════════════════

# ── Яндекс Диск (OAuth-токен — рекомендуется) ────────────────
#
# OAuth-токен даёт ПРЯМЫЕ ссылки на файлы — Karing их читает.
#
# Как получить (5 минут):
#   1. https://oauth.yandex.ru/ → "Зарегистрировать приложение"
#   2. Название: vless-collector
#   3. Платформа: "Веб-сервисы"
#   4. Redirect URI: https://oauth.yandex.ru/verification_code
#   5. Права: "Яндекс Диск" → "Запись в любом месте диска"
#   6. Нажми "Создать" → скопируй CLIENT_ID
#   7. Открой в браузере (вставь свой CLIENT_ID):
#      https://oauth.yandex.ru/authorize?response_type=token&client_id=ТВОЙ_CLIENT_ID
#   8. Разреши доступ → скопируй токен из адресной строки
#      (всё что идёт после access_token= и до первого &)
#
YANDEX_TOKEN=y0_AgAAAA_вставь_свой_токен

# ── Яндекс Диск (WebDAV — запасной вариант) ──────────────────
# Работает, но Karing не может читать файлы напрямую.
# Пароль приложения: https://id.yandex.ru/security/app-passwords
YANDEX_LOGIN=логин@yandex.ru
YANDEX_PASS=пароль_приложения

# ── Telegram-уведомления (необязательно) ─────────────────────
# Токен бота: @BotFather → /newbot
# Chat ID: @userinfobot → /start
TG_BOT_TOKEN=1234567890:AAF_токен
TG_CHAT_ID=123456789

# ── Тонкая настройка ─────────────────────────────────────────
MAX_WORKERS=80
MAX_LATENCY=4000
RELIABILITY_MIN=0.4
HISTORY_PRUNE_DAYS=7
